# ═══════════════════════════════════════════════════════════════
# Poly Poly Bot — Unified Configuration
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# ── Global ──
# PREVIEW_MODE: true = log only, false = place real bets
PREVIEW_MODE=true
PRIVATE_KEY=
PROXY_WALLET=
SIGNATURE_TYPE=0

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════════
# Strategy 1a: Copy Insiders — Geopolitical (Tier A)
# Starts automatically when STRATEGY_1A_ENABLED=true
# ═══════════════════════════════════════════════════════════════

STRATEGY_1A_ENABLED=false
STRATEGY_1A_WALLETS=
STRATEGY_1A_COPY_PERCENTAGE=10
STRATEGY_1A_MAX_BET=50
STRATEGY_1A_MIN_BET=5
STRATEGY_1A_MAX_TOTAL_EXPOSURE=500
STRATEGY_1A_MAX_PRICE=0.85
STRATEGY_1A_MIN_TRADER_BET=1000
STRATEGY_1A_HOLD_TO_SETTLEMENT=true

# ═══════════════════════════════════════════════════════════════
# Strategy 1b: Copy Whales — Leaderboard Traders (Tier B)
# ═══════════════════════════════════════════════════════════════

STRATEGY_1B_ENABLED=false
STRATEGY_1B_WALLETS=
STRATEGY_1B_COPY_PERCENTAGE=5
STRATEGY_1B_MAX_BET=25
STRATEGY_1B_MIN_BET=5
STRATEGY_1B_MAX_TOTAL_EXPOSURE=200
STRATEGY_1B_MAX_PRICE=0.90
STRATEGY_1B_MIN_PRICE=0.10
STRATEGY_1B_MIN_TRADER_BET=10000
STRATEGY_1B_HOLD_TO_SETTLEMENT=false

# ═══════════════════════════════════════════════════════════════
# Strategy 1c: Auto-Detect New Insiders (Tier C)
# ═══════════════════════════════════════════════════════════════

STRATEGY_1C_ENABLED=false
# AUTO_FOLLOW=false means alerts only, no auto-copy
STRATEGY_1C_AUTO_FOLLOW=false
STRATEGY_1C_ALERT_ONLY=true
STRATEGY_1C_COPY_PERCENTAGE=5
STRATEGY_1C_MAX_BET=10
STRATEGY_1C_MIN_BET=5
STRATEGY_1C_MAX_TOTAL_EXPOSURE=100
STRATEGY_1C_NEW_ACCOUNT_AGE_DAYS=30
STRATEGY_1C_MIN_FIRST_BET=5000
STRATEGY_1C_DORMANT_DAYS=60
# A wallet counts as "new" only if it has placed ≤ N observed trades — this
# stops scalpers from triggering new_account_geo the first time we see them.
STRATEGY_1C_MAX_LIFETIME_TRADES_FOR_NEW=5
# Comma-separated Gamma tag slugs that define "geopolitical". The market
# scanner rebuilds its cache from these tags every STRATEGY_1C_MARKET_SCAN_INTERVAL_S.
# "politics" is intentionally omitted: Gamma's politics tag is too broad
# (it catches pop-culture markets like "Russia-Ukraine Ceasefire before GTA VI").
STRATEGY_1C_GEO_TAGS=geopolitics,world,elections,ukraine,israel,middle-east,iran,russia,china,nato
STRATEGY_1C_MARKET_SCAN_INTERVAL_S=3600
# How often the market-activity poller hits /trades?market=<cid> for each geo market.
STRATEGY_1C_ACTIVITY_POLL_INTERVAL_S=60
# Cluster pattern thresholds — active Polymarket markets always have many tiny
# retail trades, so a minimum cluster volume is required to avoid noise alerts.
STRATEGY_1C_MIN_CLUSTER_VOLUME_USD=5000
STRATEGY_1C_MIN_CLUSTER_WALLET_SIZE_USD=500
# Same-funder cluster: fire when N other wallets (besides current) share a
# non-CEX USDC funder on Polygon within the 1h window. Default 4 means a
# cluster needs 5 total distinct wallets (current + 4 peers) before firing.
# Lower to 2 for more aggressive detection (at the cost of small-group noise).
STRATEGY_1C_MIN_FUNDER_CLUSTER_WALLETS=4
# Per-wallet size floor for the same-funder cluster (dedicated, separate from
# STRATEGY_1C_MIN_CLUSTER_WALLET_SIZE_USD which applies to the loose cluster).
# Each wallet in the cluster — including the current trade — must bet ≥ this
# much. Filters out small-trading-group false positives.
STRATEGY_1C_MIN_FUNDER_CLUSTER_WALLET_SIZE_USD=4000
# Don't burn Etherscan quota on wallets that already have many Polymarket trades —
# their "first funder" is too dilute to be an insider signal.
STRATEGY_1C_FUNDER_MAX_PM_TRADES=20
# Extra CEX/bridge hot wallets to exclude from funder cluster (comma-separated).
# Baseline list in src/copy_trading/wallet_funder.py is intentionally small;
# extend here as you discover false positives in your own alert stream.
STRATEGY_1C_CEX_FUNDERS=
# Late-bet pattern: large bets within N hours of market resolution.
STRATEGY_1C_CLOSE_PROXIMITY_HOURS=24
STRATEGY_1C_MIN_LATE_BET_USD=10000
# Late-bet + price edge: upgrade the alert when the bet price diverges from
# local VWAP or Gamma mid by at least this much (0-1 scale, i.e. 0.05 = 5 cents).
STRATEGY_1C_LATE_EDGE_THRESHOLD=0.05
# Thin-market dominance: flag bets that consume a large fraction of the market's
# reported book depth OR weekly volume. Geo markets on Polymarket are typically
# thin ($15k-$50k liquidity) so even retail-sized bets can dominate a book.
STRATEGY_1C_MIN_THIN_MARKET_BET_USD=2000
STRATEGY_1C_THIN_MARKET_DOMINANCE_RATIO=0.20
STRATEGY_1C_THIN_MARKET_WEEKLY_RATIO=0.50

# ── Copy Trading Advanced Settings ──
FETCH_INTERVAL=3
FETCH_CONCURRENCY=5
MAX_TRADE_AGE_HOURS=1
MAX_PRICE_DRIFT_BPS=300
MAX_SPREAD_BPS=500
# data-api | hybrid | onchain
TRADE_MONITOR_MODE=data-api
REDEEM_INTERVAL_HOURS=0.5
COPY_STRATEGY=PERCENTAGE
COPY_SIZE=10.0
MAX_ORDER_SIZE_USD=100.0
MIN_ORDER_SIZE_USD=1.0
MAX_POSITION_PER_MARKET_USD=500.0
MAX_DAILY_VOLUME_USD=1000.0
MAX_COPIES_PER_MARKET_SIDE=2

# ═══════════════════════════════════════════════════════════════
# Strategy 2: Weather Betting
# ═══════════════════════════════════════════════════════════════

STRATEGY2_ENABLED=false
CITIES_TO_BET=nyc,chicago,denver,dallas
DAYS_IN_ADVANCE=4
MIN_EDGE=0.10
BET_SIZE=10.0
MAX_BETS_PER_CITY=2
# Daily run at 3:00 PM Singapore Time
SCHEDULE_HOUR_SGT=15
SCHEDULE_MINUTE_SGT=0

# ═══════════════════════════════════════════════════════════════
# Strategy 3: Tennis Odds Arbitrage
# ═══════════════════════════════════════════════════════════════

STRATEGY3_ENABLED=false
# oddspapi (250 req/month) | scraper (The Odds API, 500 credits/month) | smarkets (FREE, real-time exchange)
# RECOMMENDED: smarkets — Smarkets is a real betting exchange with sub-second tick prices
# during in-play matches. The other two providers serve frozen pre-match closing prices
# from Pinnacle and become useless once a match starts. No registration / API key /
# payment required for smarkets — see src/odds/smarkets.py for the full rationale.
TENNIS_ODDS_PROVIDER=smarkets
ODDSPAPI_API_KEY=
# Get free key at https://the-odds-api.com/#get-access  (only needed for `scraper` provider)
THE_ODDS_API_KEY=
# Optional override for the Smarkets API base URL (defaults to https://api.smarkets.com)
SMARKETS_API_BASE=
# Minimum Smarkets traded volume (# of fills) required before a market's
# price is trusted as a sharp reference. Smarkets order books can look deep
# on the surface while being entirely untested resting quotes — the default
# threshold of 100 filters those out without losing signals on genuinely
# traded matches. Raise to 1000 for extra conservatism; drop to 50 if you
# want more Challenger-tier coverage at the cost of more false positives.
SMARKETS_MIN_VOLUME=100
TENNIS_MIN_DIVERGENCE=0.10
TENNIS_MAX_BET_SIZE=165
TENNIS_KELLY_FRACTION=0.3
# Seconds between scans outside any TENNIS_MATCH_WINDOWS (300 = every 5 min).
# Inside an active match window the per-window interval is used instead — see
# TENNIS_MATCH_WINDOWS below. We use 15s in-window because Smarkets unauth caps
# at 20 req/min and a steady-state scan costs ~3 calls (≈12/min @ 15s).
TENNIS_SCAN_INTERVAL=300
TENNIS_TOURNAMENTS=ATP,WTA
TENNIS_MIN_POLYMARKET_VOLUME=50000
TENNIS_MIN_POLYMARKET_LIQUIDITY=10000

# ═══════════════════════════════════════════════════════════════
# APIs & Infra
# ═══════════════════════════════════════════════════════════════

CLOB_API_URL=https://clob.polymarket.com
DATA_API_URL=https://data-api.polymarket.com
RPC_URL=https://polygon-rpc.com
# Free key at https://etherscan.io/apis — required for Strategy 1c wallet-age lookups.
# Without it, age lookups return None and new_account_geo checks fail closed.
ETHERSCAN_API_KEY=
GCP_PROJECT_ID=
