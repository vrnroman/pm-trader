# ═══════════════════════════════════════════════════════════════
# Poly Poly Bot — Unified Configuration
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# ── Global ──
# PREVIEW_MODE: true = log only, false = place real bets
PREVIEW_MODE=true
PRIVATE_KEY=
PROXY_WALLET=
SIGNATURE_TYPE=0

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════════
# Strategy 1a: Copy Insiders — Geopolitical (Tier A)
# Starts automatically when STRATEGY_1A_ENABLED=true
# ═══════════════════════════════════════════════════════════════

STRATEGY_1A_ENABLED=false
STRATEGY_1A_WALLETS=
STRATEGY_1A_COPY_PERCENTAGE=10
STRATEGY_1A_MAX_BET=50
STRATEGY_1A_MIN_BET=5
STRATEGY_1A_MAX_TOTAL_EXPOSURE=500
STRATEGY_1A_MAX_PRICE=0.85
STRATEGY_1A_MIN_TRADER_BET=1000
STRATEGY_1A_HOLD_TO_SETTLEMENT=true

# ═══════════════════════════════════════════════════════════════
# Strategy 1b: Copy Whales — Leaderboard Traders (Tier B)
# ═══════════════════════════════════════════════════════════════

STRATEGY_1B_ENABLED=false
STRATEGY_1B_WALLETS=
STRATEGY_1B_COPY_PERCENTAGE=5
STRATEGY_1B_MAX_BET=25
STRATEGY_1B_MIN_BET=5
STRATEGY_1B_MAX_TOTAL_EXPOSURE=200
STRATEGY_1B_MAX_PRICE=0.90
STRATEGY_1B_MIN_PRICE=0.10
STRATEGY_1B_MIN_TRADER_BET=10000
STRATEGY_1B_HOLD_TO_SETTLEMENT=false

# ═══════════════════════════════════════════════════════════════
# Strategy 1c: Auto-Detect New Insiders (Tier C)
# ═══════════════════════════════════════════════════════════════

STRATEGY_1C_ENABLED=false
# AUTO_FOLLOW=false means alerts only, no auto-copy
STRATEGY_1C_AUTO_FOLLOW=false
STRATEGY_1C_ALERT_ONLY=true
STRATEGY_1C_COPY_PERCENTAGE=5
STRATEGY_1C_MAX_BET=10
STRATEGY_1C_MIN_BET=5
STRATEGY_1C_MAX_TOTAL_EXPOSURE=100
STRATEGY_1C_NEW_ACCOUNT_AGE_DAYS=30
STRATEGY_1C_MIN_FIRST_BET=5000
STRATEGY_1C_DORMANT_DAYS=60
# A wallet counts as "new" only if it has placed ≤ N observed trades — this
# stops scalpers from triggering new_account_geo the first time we see them.
STRATEGY_1C_MAX_LIFETIME_TRADES_FOR_NEW=5
# Comma-separated Gamma tag slugs that define "geopolitical". The market
# scanner rebuilds its cache from these tags every STRATEGY_1C_MARKET_SCAN_INTERVAL_S.
# "politics" is intentionally omitted: Gamma's politics tag is too broad
# (it catches pop-culture markets like "Russia-Ukraine Ceasefire before GTA VI").
STRATEGY_1C_GEO_TAGS=geopolitics,world,elections,ukraine,israel,middle-east,iran,russia,china,nato
STRATEGY_1C_MARKET_SCAN_INTERVAL_S=3600
# How often the market-activity poller hits /trades?market=<cid> for each geo market.
STRATEGY_1C_ACTIVITY_POLL_INTERVAL_S=60
# Cluster pattern thresholds — active Polymarket markets always have many tiny
# retail trades, so a minimum cluster volume is required to avoid noise alerts.
STRATEGY_1C_MIN_CLUSTER_VOLUME_USD=5000
STRATEGY_1C_MIN_CLUSTER_WALLET_SIZE_USD=500
# Same-funder cluster: fire when N other wallets (besides current) share a
# non-CEX USDC funder on Polygon within the 1h window. Default 4 means a
# cluster needs 5 total distinct wallets (current + 4 peers) before firing.
# Lower to 2 for more aggressive detection (at the cost of small-group noise).
STRATEGY_1C_MIN_FUNDER_CLUSTER_WALLETS=4
# Per-wallet size floor for the same-funder cluster (dedicated, separate from
# STRATEGY_1C_MIN_CLUSTER_WALLET_SIZE_USD which applies to the loose cluster).
# Each wallet in the cluster — including the current trade — must bet ≥ this
# much. Filters out small-trading-group false positives.
STRATEGY_1C_MIN_FUNDER_CLUSTER_WALLET_SIZE_USD=4000
# Don't burn Etherscan quota on wallets that already have many Polymarket trades —
# their "first funder" is too dilute to be an insider signal.
STRATEGY_1C_FUNDER_MAX_PM_TRADES=20
# Extra CEX/bridge hot wallets to exclude from funder cluster (comma-separated).
# Baseline list in src/copy_trading/wallet_funder.py is intentionally small;
# extend here as you discover false positives in your own alert stream.
STRATEGY_1C_CEX_FUNDERS=
# Late-bet pattern: large bets within N hours of market resolution.
STRATEGY_1C_CLOSE_PROXIMITY_HOURS=24
STRATEGY_1C_MIN_LATE_BET_USD=10000
# Late-bet + price edge: upgrade the alert when the bet price diverges from
# local VWAP or Gamma mid by at least this much (0-1 scale, i.e. 0.05 = 5 cents).
STRATEGY_1C_LATE_EDGE_THRESHOLD=0.05
# Thin-market dominance: flag bets that consume a large fraction of the market's
# reported book depth OR weekly volume. Geo markets on Polymarket are typically
# thin ($15k-$50k liquidity) so even retail-sized bets can dominate a book.
STRATEGY_1C_MIN_THIN_MARKET_BET_USD=2000
STRATEGY_1C_THIN_MARKET_DOMINANCE_RATIO=0.20
STRATEGY_1C_THIN_MARKET_WEEKLY_RATIO=0.50

# ── Copy Trading Advanced Settings ──
FETCH_INTERVAL=3
FETCH_CONCURRENCY=5
MAX_TRADE_AGE_HOURS=1
MAX_PRICE_DRIFT_BPS=300
MAX_SPREAD_BPS=500
# data-api | hybrid | onchain
TRADE_MONITOR_MODE=data-api
REDEEM_INTERVAL_HOURS=0.5
COPY_STRATEGY=PERCENTAGE
COPY_SIZE=10.0
MAX_ORDER_SIZE_USD=100.0
MIN_ORDER_SIZE_USD=1.0
MAX_POSITION_PER_MARKET_USD=500.0
MAX_DAILY_VOLUME_USD=1000.0
MAX_COPIES_PER_MARKET_SIDE=2

# Strategy 2 (Weather Betting) and Strategy 3 (Tennis Arbitrage) were
# decommissioned on 2026-06-17. Their config keys have been removed; see
# DECOMMISSIONED.md to restore them from git history.

# ═══════════════════════════════════════════════════════════════
# Copy-paper harness (Strategy 1b validation — PREVIEW only, NO real orders)
# ═══════════════════════════════════════════════════════════════
# Forward-measures execution-realistic copy PnL on a watchlist of wallets,
# tracking each paper position to resolution. Graduate a wallet to real capital
# only after its net-of-drag PnL is positive in the ledger
# (scripts/copy_paper_run.py --report).
#
# First generate a watchlist (ranks wallets by realized closed-position ROI —
# the validated selection method; see research/COPY_TRADING_FINDINGS.md):
#   python -m backtest.trader_scoring_backtest watchlist --category research \
#       --top-k 20 --output data/copy_watchlist.json
COPY_PAPER_ENABLED=true
COPY_PAPER_WATCHLIST=data/copy_watchlist.json
COPY_PAPER_LEDGER=data/copy_paper_ledger.jsonl
COPY_PAPER_MAX_USD=50            # max USDC per simulated copy
COPY_PAPER_COPY_PCT=1.0          # fraction of target's size to mirror (pre-cap)
COPY_PAPER_MAX_SLIPPAGE_BPS=200  # don't chase a copy past this over their price
COPY_PAPER_MAX_AGE_S=21600       # only copy target trades fresher than this (6h)
COPY_PAPER_MIN_USD=500           # ignore target trades smaller than this
COPY_PAPER_INTERVAL_S=120        # cycle cadence
# Entry guardrails (cut the copies that historically leaked ROI; cap<=0 disables)
COPY_PAPER_FILL_GATE_BPS=150       # skip a copy whose fill is >150bps above their price (don't chase)
COPY_PAPER_FIRST_ENTRY_ONLY=true   # copy the opening trade per market, not averaging-down adds
COPY_PAPER_MAX_PER_WALLET_DAY=3    # slate circuit-breaker: max copies/UTC-day per wallet
COPY_PAPER_MAX_PER_CATEGORY_DAY=8  # slate circuit-breaker: max copies/UTC-day per category

# Wallet discovery (continuously hunts copyable wallets -> Telegram + auto-paper)
# Runs the funnel (universe -> robust skill -> lead-lag copyability) on a
# schedule; pings Telegram on each new qualifier and writes it to the paper
# watchlist above. NEVER places real orders or edits live tiers.
# Pair with COPY_PAPER_ENABLED=true so the ledger measures the wallets it finds.
WALLET_DISCOVERY_ENABLED=true
# Wide insider sweep: scan a big universe on a slow cadence (everyone scans the
# same ~850 top wallets — insiders hide in the long tail). The funnel streams
# scoring in chunks (memory-bounded) and paces requests to dodge 429s.
WALLET_DISCOVERY_INTERVAL_S=86400       # sweep cadence (1d; keep ACTIVITY_TTL_S above this)
WALLET_DISCOVERY_UNIVERSE=200000        # cap on wallets pulled in (take whatever we find)
# /trades hard-caps pagination at offset 3000, so the trade feed alone yields
# only a few thousand wallets; reaching 200k needs the market-iterating sources.
WALLET_DISCOVERY_UNIVERSE_MAX_OFFSET=3000    # API rejects offsets > 3000 (HTTP 400)
WALLET_DISCOVERY_PAGE_PAUSE_S=0.3       # pause between /trades pages while building universe
WALLET_DISCOVERY_BATCH_PAUSE_S=0.5      # pause between 100-wallet /activity batches (8 workers ~148/s, 0 429s)
WALLET_DISCOVERY_CHUNK=100              # wallets fetched+scored per batch (OOM guard)
WALLET_DISCOVERY_SKILL_POOL=40          # top-skill wallets deep-checked for copyability
WALLET_DISCOVERY_CAP=25                 # max wallets kept on the paper watchlist
WALLET_DISCOVERY_MIN_CAPTURE_CENTS=1.5  # qualify bar: capture >= this (cents/trade)
WALLET_DISCOVERY_MIN_TSTAT=10           # qualify bar: skill t-stat >= this
WALLET_DISCOVERY_DROP_CAPTURE_CENTS=1.0 # hysteresis: drop only once capture < this
WALLET_DISCOVERY_AUTO_REMOVE=true       # remove decayed wallets from paper
WALLET_DISCOVERY_CATEGORY=ALL           # restrict skill scoring to a category, or ALL
WALLET_DISCOVERY_CACHE_DIR=data/wcache  # TTL-cached wallet activity
WALLET_DISCOVERY_STATE=data/discovery_state.json
# Universe = wallets active in the last N seconds (0 = legacy top-stake offset paging).
WALLET_DISCOVERY_UNIVERSE_WINDOW_S=86400     # 24h-active universe
WALLET_DISCOVERY_EXPAND_FILTERS=false        # also page BUY/SELL x taker (wider, ~20x requests)
# Activity-cache TTL doubles as the disk-eviction horizon (prune_cache runs each
# sweep). Keep it just under the scan interval so each sweep re-fetches fresh once.
WALLET_DISCOVERY_ACTIVITY_TTL_S=108000       # 30h (must exceed INTERVAL_S to benefit)
WALLET_DISCOVERY_CACHE_MAX_FILES=15000       # hard cap on cached activity files (disk guard)
# Gated Claude second-opinion on the top-N qualified wallets (alert-only, needs ANTHROPIC_API_KEY).
WALLET_DISCOVERY_LLM_REVIEW_ENABLED=false
WALLET_DISCOVERY_LLM_REVIEW_TOP_N=5
WALLET_DISCOVERY_LLM_MODEL=claude-opus-4-8
# Independent theories that may qualify a wallet (OR'd). See research/THEORY_FINDINGS.md.
# Backtest-supported set; add 1a/1e/1j to experiment.
WALLET_DISCOVERY_THEORIES=1b,1c,1d,1f,1g,1h,1i
# Copy-replay selection gate: score each candidate on OUR copy action (copy its
# copyable BUYs, hold to resolution) and drop wallets with a proven-negative
# copy-and-hold edge regardless of theory; rank copy-validated wallets first.
WALLET_DISCOVERY_COPY_REPLAY_GATE=true
WALLET_DISCOVERY_MIN_COPY_REPLAY_N=12       # resolved replayed copies before judging a wallet
WALLET_DISCOVERY_MIN_COPY_REPLAY_ROI=0.0    # mean copy-and-hold ROI/$ bar to qualify
WALLET_DISCOVERY_FADE_ROI=-0.10             # at/below this (with enough n) -> FADE label
# Strategy 4 — long-horizon bet tracking. The copy funnel (Strategy 1) scores
# wallets on provably-closed markets, so it can't judge a wallet that bets on
# events resolving 6+ months out. When enabled, the sweep classifies each
# candidate by how early it bets before resolution (fetching end dates for its
# still-open markets too) and routes long-horizon-dominated wallets to a separate
# watchlist — tracked, not copied. Off by default (zero extra Gamma calls).
STRATEGY_4_ENABLED=false
STRATEGY_4_LONG_HORIZON_DAYS=180            # a bet is "long-horizon" if placed >= this many days pre-resolution (6mo)
STRATEGY_4_MIN_LONG_RATIO=0.5               # wallet is Strategy 4 if >= this share of dated buy $ is long-horizon
STRATEGY_4_MIN_DATED_BUYS=5                 # need this many dated buys before classifying (else defaults to Strategy 1)
STRATEGY_4_CAP=25                           # max wallets on the long-horizon watchlist
WALLET_DISCOVERY_LONG_HORIZON_WATCHLIST=data/long_horizon_watchlist.json

# ═══════════════════════════════════════════════════════════════
# APIs & Infra
# ═══════════════════════════════════════════════════════════════

CLOB_API_URL=https://clob.polymarket.com
DATA_API_URL=https://data-api.polymarket.com
RPC_URL=https://polygon-rpc.com
# Free key at https://etherscan.io/apis — required for Strategy 1c wallet-age lookups.
# Without it, age lookups return None and new_account_geo checks fail closed.
ETHERSCAN_API_KEY=
GCP_PROJECT_ID=
